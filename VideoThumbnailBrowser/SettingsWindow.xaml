<Window x:Class="VideoThumbnailBrowser.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="520" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252526">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- サムネイル枚数 -->
        <TextBlock Grid.Row="0" Text="サムネイル枚数（1動画あたり）" Foreground="White" Margin="0,0,0,4"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Slider x:Name="ThumbnailCountSlider" Width="300" Minimum="1" Maximum="30"
                    Value="{Binding ThumbnailsPerVideo}" TickFrequency="1" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ThumbnailsPerVideo}" Foreground="White"
                       Margin="8,0,0,0" VerticalAlignment="Center" Width="24"/>
        </StackPanel>

        <!-- サムネイル表示幅 -->
        <TextBlock Grid.Row="2" Text="サムネイル表示サイズ（幅px）" Foreground="White" Margin="0,0,0,4"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,20">
            <Slider x:Name="ThumbnailWidthSlider" Width="300" Minimum="80" Maximum="480"
                    Value="{Binding ThumbnailDisplayWidth}" TickFrequency="10" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ThumbnailDisplayWidth}" Foreground="White"
                       Margin="8,0,0,0" VerticalAlignment="Center" Width="32"/>
        </StackPanel>

        <!-- 1ページあたりの表示件数 -->
        <TextBlock Grid.Row="4" Text="1ページあたりの表示件数" Foreground="White" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Slider Width="300" Minimum="5" Maximum="200"
                    Value="{Binding PageSize}" TickFrequency="5" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Text="{Binding PageSize}" Foreground="White"
                       Margin="8,0,0,0" VerticalAlignment="Center" Width="32"/>
        </StackPanel>

        <!-- 動画用起動ソフト -->
        <TextBlock Grid.Row="4" Text="🎬 動画用起動ソフト（最大3つ）" Foreground="White"
                   FontWeight="Bold" Margin="0,0,0,6"/>
        <ItemsControl Grid.Row="5" x:Name="VideoAppList" Margin="0,0,0,16">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="1" Text="{Binding ExePath}" Background="#3C3C3C"
                                 Foreground="White" BorderBrush="#555" Padding="4,2"/>
                        <Button Grid.Column="2" Content="参照..." Margin="4,0,0,0"
                                Padding="4,2" Tag="{Binding}" Click="OnBrowseAppClick"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 書庫用起動ソフト -->
        <TextBlock Grid.Row="6" Text="📦 書庫用起動ソフト（最大3つ）" Foreground="White"
                   FontWeight="Bold" Margin="0,0,0,6" VerticalAlignment="Top"/>
        <ItemsControl Grid.Row="6" x:Name="ArchiveAppList" Margin="0,24,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="1" Text="{Binding ExePath}" Background="#3C3C3C"
                                 Foreground="White" BorderBrush="#555" Padding="4,2"/>
                        <Button Grid.Column="2" Content="参照..." Margin="4,0,0,0"
                                Padding="4,2" Tag="{Binding}" Click="OnBrowseAppClick"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ボタン -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Padding="4"
                    IsDefault="True" Click="OnOkClick"/>
            <Button Content="キャンセル" Width="80" Padding="4" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
