<Window x:Class="VideoThumbnailBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VideoThumbnailBrowser.ViewModels"
        xmlns:controls="clr-namespace:VideoThumbnailBrowser.Controls"
        xmlns:models="clr-namespace:VideoThumbnailBrowser.Models"
        Title="PinkBrowser" Height="800" Width="1400"
        WindowState="Maximized" WindowStartupLocation="CenterScreen"
        KeyDown="OnWindowKeyDown"
        Background="#252526" Icon="app.ico">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel>
        <!-- トップバー -->
        <DockPanel DockPanel.Dock="Top" Background="#2D2D30" LastChildFill="False">

            <!-- ハンバーガーボタン -->
            <Button DockPanel.Dock="Left" x:Name="SidebarToggleButton"
                    Content="☰" FontSize="16" Padding="10,4" Margin="2,2"
                    Background="Transparent" BorderThickness="0" Foreground="White"
                    Click="OnSidebarToggle" ToolTip="フォルダーパネル"/>

            <Menu DockPanel.Dock="Left" Background="Transparent" VerticalAlignment="Center">
                <MenuItem Header="ファイル">
                    <MenuItem Header="フォルダーを追加..." Command="{Binding AddFolderCommand}"/>
                    <MenuItem Header="再スキャン（差分のみ）" Command="{Binding RescanAllCommand}"/>
                    <MenuItem Header="サムネイルを再生成（全体）" Command="{Binding RescanAllWithRegenerateCommand}"/>
                    <Separator/>
                    <MenuItem Header="終了" Click="OnExitClick"/>
                </MenuItem>
                <MenuItem Header="プロファイル">
                    <MenuItem Header="新規作成..." Command="{Binding AddProfileCommand}"/>
                    <Separator/>
                    <ItemsControl ItemsSource="{Binding Profiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DbProfile}">
                                <MenuItem Header="{Binding Name}"
                                          Command="{Binding DataContext.SwitchProfileCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator/>
                    <MenuItem Header="現在のプロファイルを削除"
                              Command="{Binding DeleteProfileCommand}"
                              CommandParameter="{Binding Profiles[0]}"/>
                </MenuItem>
                <MenuItem Header="ツール">
                    <MenuItem Header="設定..." Command="{Binding OpenSettingsCommand}"/>
                </MenuItem>
            </Menu>

            <!-- プロファイル名 -->
            <TextBlock DockPanel.Dock="Left" Foreground="#AAAAFF" VerticalAlignment="Center"
                       Margin="8,0" FontSize="12">
                <Run Text="📁"/><Run Text="{Binding ActiveProfileName}"/>
            </TextBlock>

            <Separator DockPanel.Dock="Left"
                       Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,4"/>

            <!-- 並べ替え -->
            <TextBlock DockPanel.Dock="Left" Text="並べ替え:" Foreground="#CCCCCC"
                       VerticalAlignment="Center" Margin="4,0"/>
            <Button DockPanel.Dock="Left" x:Name="SortButton"
                    Padding="10,4" Margin="2,3" Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555" Click="OnSortButtonClick">
                <Button.Content>
                    <TextBlock>
                        <Run x:Name="SortKeyText" Text="ファイル名"/>
                        <Run x:Name="SortDirText" Text=" ↑"/>
                    </TextBlock>
                </Button.Content>
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="ファイル名" Tag="FileName" Click="OnSortMenuClick"/>
                        <MenuItem Header="登録日時"   Tag="RegisteredAt" Click="OnSortMenuClick"/>
                        <MenuItem Header="更新日時"   Tag="LastWriteTime" Click="OnSortMenuClick"/>
                        <MenuItem Header="再生回数"   Tag="PlayCount" Click="OnSortMenuClick"/>
                        <MenuItem Header="評価"       Tag="Rating" Click="OnSortMenuClick"/>
                        <MenuItem Header="ファイルサイズ" Tag="FileSize" Click="OnSortMenuClick"/>
                        <MenuItem Header="動画時間"   Tag="Duration" Click="OnSortMenuClick"/>
                        <MenuItem Header="タグ数"     Tag="TagCount" Click="OnSortMenuClick"/>
                        <MenuItem Header="パス順"     Tag="FolderPath" Click="OnSortMenuClick"/>
                        <Separator/>
                        <MenuItem Header="昇順 ↑" Click="OnSortAscClick"/>
                        <MenuItem Header="降順 ↓" Click="OnSortDescClick"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <Separator DockPanel.Dock="Left"
                       Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,4"/>

            <!-- 評価フィルター -->
            <Button DockPanel.Dock="Left" x:Name="RatingFilterButton"
                    Content="{Binding RatingFilterLabel}"
                    Padding="10,4" Margin="2,3" Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555" Click="OnRatingFilterClick">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="すべての評価" Tag="0" Click="OnRatingMenuItemClick"/>
                        <Separator/>
                        <MenuItem Header="★1 以上" Tag="1" Click="OnRatingMenuItemClick"/>
                        <MenuItem Header="★2 以上" Tag="2" Click="OnRatingMenuItemClick"/>
                        <MenuItem Header="★3 以上" Tag="3" Click="OnRatingMenuItemClick"/>
                        <MenuItem Header="★4 以上" Tag="4" Click="OnRatingMenuItemClick"/>
                        <MenuItem Header="★5 のみ"  Tag="5" Click="OnRatingMenuItemClick"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <!-- 種別フィルター -->
            <Button DockPanel.Dock="Left" Content="{Binding KindFilterLabel}"
                    Padding="10,4" Margin="2,3" Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555" Click="OnKindFilterClick">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="すべて" Tag="All" Click="OnKindMenuClick"/>
                        <MenuItem Header="🎬 動画のみ" Tag="Video" Click="OnKindMenuClick"/>
                        <MenuItem Header="📦 書庫のみ" Tag="Archive" Click="OnKindMenuClick"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <!-- タグフィルター -->
            <Button DockPanel.Dock="Left" x:Name="TagFilterButton"
                    Content="{Binding TagFilterLabel}"
                    Padding="10,4" Margin="2,3" Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555" Click="OnTagFilterClick">
                <Button.ContextMenu>
                    <ContextMenu x:Name="TagContextMenu" Opened="OnTagContextMenuOpened">
                        <MenuItem Header="タグ絞り込みをクリア"
                                  Command="{Binding ClearTagFilterCommand}"/>
                        <Separator/>
                        <ItemsControl ItemsSource="{Binding TagFilterItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TagFilterItem}">
                                    <MenuItem IsCheckable="True"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              Header="{Binding Name}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <!-- フィルタークリア -->
            <Button DockPanel.Dock="Left" Content="✕ クリア"
                    Padding="8,4" Margin="2,3" Background="#5A3A3A" Foreground="White"
                    BorderBrush="#884444" Click="OnClearAllFiltersClick">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnyFilterActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </DockPanel>

        <!-- メインレイアウト -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- サイドバー（幅0で非表示スタート） -->
                <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="DetailColumn" Width="0"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- トークンバー -->
                <RowDefinition Height="Auto"/> <!-- 検索バー -->
                <RowDefinition Height="*"/>    <!-- サムネイル -->
                <RowDefinition Height="Auto"/> <!-- 選択バー -->
                <RowDefinition Height="Auto"/> <!-- ページネーション -->
                <RowDefinition Height="Auto"/> <!-- ステータス -->
            </Grid.RowDefinitions>

            <!-- 左: フォルダツリー（スライドイン） -->
            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="6"
                    Background="#2D2D30" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0">
                <DockPanel Margin="6">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Left" Text="フォルダー" Foreground="White"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="＋" Width="22" Height="22"
                                Padding="0" FontSize="14"
                                Command="{Binding AddFolderCommand}" ToolTip="フォルダーを追加"/>
                    </DockPanel>
                    <TreeView ItemsSource="{Binding FolderTree}"
                              Background="Transparent" BorderThickness="0" Foreground="White">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="2,1"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding FullPath}"
                                           Padding="2,1"
                                           MouseLeftButtonUp="OnFolderNodeClicked">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="このフォルダで絞り込む" Click="OnFolderFilterClick"/>
                                            <MenuItem Header="絞り込みを解除"
                                                      Command="{Binding DataContext.ClearFolderFilterCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Separator/>
                                            <MenuItem Header="このフォルダを再スキャン" Click="OnRescanFolderClick"/>
                                            <Separator/>
                                            <MenuItem Header="監視フォルダから登録解除..." Click="OnRemoveFolderClick"
                                                      Foreground="#FF6666"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- トークンバー（検索バーの上） -->
            <Border Grid.Column="1" Grid.Row="0" Background="#1A1A2E" Padding="6,4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="🔤" VerticalAlignment="Center"
                               Margin="0,0,6,0" Foreground="#888" FontSize="11"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="GlobalTokenPanel"
                                      ItemsSource="{Binding CurrentTokens}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2,1" Padding="5,2"
                                            Background="#2A2A4A" CornerRadius="3"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="OnGlobalTokenLeftClick"
                                            MouseRightButtonUp="OnGlobalTokenRightClick">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="検索バーに追加" Click="OnGlobalTokenSearchClick"/>
                                                <MenuItem Header="タグに登録（選択中の動画へ）" Click="OnGlobalTokenTagClick"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <TextBlock Text="{Binding}" Foreground="#CCCCFF"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 検索バー -->
            <Grid Grid.Column="1" Grid.Row="1" Margin="8,4,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4" Background="#3C3C3C" Foreground="White" BorderBrush="#3A3A3A"/>
                <TextBlock Grid.Column="0" Foreground="Gray" Margin="9,6,0,0" IsHitTestVisible="False"
                           Text="ファイル名、tag:タグ名、rating:5 で検索...">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Grid.Column="1" x:Name="SearchClearButton"
                        Content="✕" Width="28" Padding="0"
                        Background="#3C3C3C" Foreground="#AAAAAA" BorderBrush="#3A3A3A"
                        Visibility="Collapsed"
                        ToolTip="検索をクリア" Click="OnSearchClearClick"/>
            </Grid>

            <!-- サムネイル一覧 -->
            <ScrollViewer Grid.Column="1" Grid.Row="2" x:Name="ThumbnailScrollViewer"
                          AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop"
                          VerticalScrollBarVisibility="Auto" Margin="4,0"
                          SizeChanged="ThumbnailScrollViewer_SizeChanged">
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical"
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.VirtualizationMode="Recycling"
                                VirtualizingPanel.ScrollUnit="Pixel"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:RowViewModel}">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:VideoItemViewModel}">
                                        <controls:ScrubThumbnailControl
                                            VideoItem="{Binding}"
                                            EditTagsCommand="{Binding DataContext.EditTagsCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToggleSelectCommand="{Binding DataContext.ToggleSelectCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            Width="{Binding DataContext.ThumbnailDisplayWidth,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            Height="{Binding DataContext.ThumbnailDisplayHeight,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            Margin="4"
                                            MouseDoubleClick="OnThumbnailDoubleClick"
                                            MouseLeftButtonUp="OnThumbnailClicked"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 右: 詳細パネル -->
            <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="6"
                    Background="#2D2D30" BorderBrush="#3A3A3A" BorderThickness="1,0,0,0">
                <DockPanel Margin="12" DataContext="{Binding DetailPanel}">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left" Text="詳細情報" Foreground="White"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="✕" Padding="6,2"
                                Command="{Binding DataContext.CloseDetailCommand,
                                    RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Visibility="{Binding IsVisible,
                            Converter={StaticResource BoolToVisibilityConverter}}">
                            <Image Source="{Binding Item.CoverImage}"
                                   MaxHeight="160" Stretch="Uniform" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Item.FileName}" Foreground="White"
                                       FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="登録日時" Foreground="Gray" Margin="0,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Item.RegisteredAtText}" Foreground="White" Margin="0,2" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="動画時間" Foreground="Gray" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Item.DurationText}" Foreground="White" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="サイズ" Foreground="Gray" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Item.FileSizeText}" Foreground="White" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="再生回数" Foreground="Gray" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Item.PlayCount}" Foreground="White" Margin="0,2"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="評価" Foreground="Gray" Margin="0,2"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Item.Rating}" Foreground="Gold" Margin="0,2"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="タグ" Foreground="Gray" Margin="0,2"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Item.TagsText}" Foreground="#AAAAFF" Margin="0,2" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="パス" Foreground="Gray" Margin="0,2"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Item.FilePath}" Foreground="White" Margin="0,2" TextWrapping="Wrap" FontSize="10"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 選択中バー -->
            <Border Grid.Column="1" Grid.Row="3" Background="#3C3C00" Padding="8,5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="タグを一括付与..." Padding="10,3" Margin="0,0,8,0"
                                Command="{Binding BulkTagCommand}"/>
                        <Button Content="選択解除" Padding="10,3"
                                Command="{Binding ClearSelectionCommand}"/>
                    </StackPanel>
                    <TextBlock VerticalAlignment="Center" Foreground="White">
                        <Run Text="{Binding SelectedCount, Mode=OneWay}"/><Run Text=" 件を選択中"/>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- ページネーション -->
            <Border Grid.Column="1" Grid.Row="4" Background="#1E1E1E" Padding="6,4">
                <DockPanel>
                    <!-- 件数表示 -->
                    <TextBlock DockPanel.Dock="Left" Foreground="Gray"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11">
                        <Run Text="{Binding TotalCount, Mode=OneWay}"/><Run Text=" 件中 "/>
                        <Run Text="{Binding PageStartIndex, Mode=OneWay}"/><Run Text="–"/>
                        <Run Text="{Binding PageEndIndex, Mode=OneWay}"/><Run Text=" 件"/>
                    </TextBlock>

                    <!-- ページ操作 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- 前へ（30/20/10/1ページ） -->
                        <Button Content="◀◀◀" Padding="6,3" Margin="0,0,1,0"
                                ToolTip="-30ページ"
                                Command="{Binding JumpPageCommand}" CommandParameter="-30"/>
                        <Button Content="◀◀" Padding="6,3" Margin="0,0,1,0"
                                ToolTip="-20ページ"
                                Command="{Binding JumpPageCommand}" CommandParameter="-20"/>
                        <Button Content="◀" Padding="6,3" Margin="0,0,1,0"
                                ToolTip="-10ページ"
                                Command="{Binding JumpPageCommand}" CommandParameter="-10"/>
                        <Button Content="‹" FontSize="14" Padding="6,3" Margin="0,0,2,0"
                                ToolTip="前のページ"
                                Command="{Binding PrevPageCommand}"/>

                        <!-- ページ番号ボタン列 -->
                        <ItemsControl ItemsSource="{Binding PageNumbers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}" Width="32" Padding="0,3"
                                            Margin="1,0"
                                            Command="{Binding DataContext.GoToPageCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#3C3C3C"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#555"/>
                                                <Style.Triggers>
                                                    <!-- 現在ページは強調表示 -->
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <StaticResource ResourceKey="EqualConverter"/>
                                                                </MultiBinding.Converter>
                                                                <Binding/>
                                                                <Binding Path="DataContext.CurrentPage"
                                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="#007ACC"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 次へ（1/10/20/30ページ） -->
                        <Button Content="›" FontSize="14" Padding="6,3" Margin="2,0,1,0"
                                ToolTip="次のページ"
                                Command="{Binding NextPageCommand}"/>
                        <Button Content="▶" Padding="6,3" Margin="0,0,1,0"
                                ToolTip="+10ページ"
                                Command="{Binding JumpPageCommand}" CommandParameter="10"/>
                        <Button Content="▶▶" Padding="6,3" Margin="0,0,1,0"
                                ToolTip="+20ページ"
                                Command="{Binding JumpPageCommand}" CommandParameter="20"/>
                        <Button Content="▶▶▶" Padding="6,3" Margin="0,0,0,0"
                                ToolTip="+30ページ"
                                Command="{Binding JumpPageCommand}" CommandParameter="30"/>

                        <!-- ページ直接入力 -->
                        <TextBlock Text="/" Foreground="Gray" VerticalAlignment="Center" Margin="6,0,2,0"/>
                        <TextBlock Text="{Binding TotalPages}" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="PageInputBox" Width="40" Padding="4,2"
                                 Background="#3C3C3C" Foreground="White" BorderBrush="#555"
                                 ToolTip="ページ番号を入力してEnter"
                                 KeyDown="OnPageInputKeyDown"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ステータスバー -->
            <Border Grid.Column="1" Grid.Row="5" Background="#007ACC" Padding="8,3">
                <TextBlock Text="{Binding StatusText}" Foreground="White"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
